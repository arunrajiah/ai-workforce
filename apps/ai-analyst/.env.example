# Offline demo mode works with NO configuration (built-in example questions run).
# To enable full natural-language querying, point at any OpenAI-compatible chat
# endpoint (Ollama, LiteLLM, LocalAI, vLLM, or a hosted gateway).
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.1
LLM_API_KEY=

# Optional
CSV_PATH=./data/sales.csv
