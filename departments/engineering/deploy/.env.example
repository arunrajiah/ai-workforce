# ─────────────────────────────────────────────────────────────────────────────
# Engineering / DevOps one-click deploy — copy to .env and fill in.
#   cp .env.example .env
# Generate secrets with:  openssl rand -hex 24   (passwords / tokens)
# ─────────────────────────────────────────────────────────────────────────────

# --- Your domain (point its DNS A record at this server) ---
DOMAIN=dev.example.com
ACME_EMAIL=you@example.com

# --- OpenHands sandbox runtime ---
# The image OpenHands launches to run the agent's code. Keep the version in sync
# with the openhands app image in docker-compose.yml (currently 0.55).
SANDBOX_RUNTIME_CONTAINER_IMAGE=docker.all-hands.dev/all-hands-ai/runtime:0.55-nikolaik

# ─────────────────────────────────────────────────────────────────────────────
# LLM (provider-neutral — any OpenAI-compatible endpoint)
# ─────────────────────────────────────────────────────────────────────────────
# You can also skip these and configure the model in the OpenHands UI on first run.
# Point at any OpenAI-compatible endpoint: a local Ollama/vLLM, a LiteLLM proxy,
# or a hosted gateway. Example base URL for a local Ollama: http://host.docker.internal:11434/v1
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=
