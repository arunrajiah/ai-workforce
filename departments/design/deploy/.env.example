# ─────────────────────────────────────────────────────────────────────────────
# Design & Creative one-click deploy — copy to .env and fill in.
#   cp .env.example .env
# Generate secrets with:  openssl rand -hex 24   (passwords / tokens)
# ─────────────────────────────────────────────────────────────────────────────

# --- Your domain (point its DNS A record at this server) ---
DOMAIN=studio.example.com
ACME_EMAIL=you@example.com

# --- ComfyUI image ---
# GPU (default, recommended):  yanwk/comfyui-boot:cu126-megapak
# Smaller CUDA image:          yanwk/comfyui-boot:cu130-slim-v2
# CPU-only (very slow):        yanwk/comfyui-boot:cpu
#   (with the CPU image, also comment out the `deploy:` block in docker-compose.yml)
COMFYUI_IMAGE=yanwk/comfyui-boot:cu126-megapak

# ─────────────────────────────────────────────────────────────────────────────
# AI prompt-expansion (optional — see GO-LIVE.md)
# ─────────────────────────────────────────────────────────────────────────────
# An n8n flow can take a short brief, expand it into a rich prompt via any
# OpenAI-compatible endpoint, then POST to ComfyUI's /prompt API. Leave blank to
# skip; ComfyUI works fully on its own.
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=
