# ─────────────────────────────────────────────────────────────────────────────
# Data & Analytics one-click deploy — copy to .env and fill in.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# --- Your domain (point its DNS A record at this server) ---
DOMAIN=analytics.example.com
ACME_EMAIL=you@example.com

# ─────────────────────────────────────────────────────────────────────────────
# AI Analyst (ask plain-English questions over a CSV → SQL + results table)
# ─────────────────────────────────────────────────────────────────────────────
# Leave LLM_* blank to run the analyst in offline demo mode (built-in examples).
# To turn any question into SQL, point at any OpenAI-compatible endpoint
# (Ollama, LiteLLM, LocalAI, vLLM, or a hosted gateway).
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=
