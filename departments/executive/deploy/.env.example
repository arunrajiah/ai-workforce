# ─────────────────────────────────────────────────────────────────────────────
# Executive / Assistant one-click deploy — copy to .env and fill in.
#   cp .env.example .env
# Generate secrets with:  openssl rand -hex 32   (KHOJ_DJANGO_SECRET_KEY)
#                         openssl rand -hex 24   (passwords)
# ─────────────────────────────────────────────────────────────────────────────

# --- Your domain (point its DNS A record at this server) ---
DOMAIN=assistant.example.com
ACME_EMAIL=you@example.com

# --- Database (Postgres/pgvector) ---
POSTGRES_DB=khoj
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_with_a_strong_password

# --- Khoj core ---
KHOJ_DJANGO_SECRET_KEY=replace_with_openssl_rand_hex_32
KHOJ_ADMIN_EMAIL=you@example.com
KHOJ_ADMIN_PASSWORD=replace_with_a_strong_password

# ─────────────────────────────────────────────────────────────────────────────
# LLM — provider-neutral (OpenAI-compatible endpoint)
# ─────────────────────────────────────────────────────────────────────────────
# Leave these blank to configure the model interactively in Khoj's admin UI
# (recommended — see GO-LIVE.md Step 6). To wire a provider up front, point at
# any OpenAI-compatible endpoint. For a local/private model, run Ollama on the
# host and use:
#   LLM_BASE_URL=http://host.docker.internal:11434/v1/
#   LLM_MODEL=llama3.1           # set the model in the admin UI (see Step 6)
#   LLM_API_KEY=ollama           # any non-empty placeholder for local Ollama
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=
