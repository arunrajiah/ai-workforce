# ─────────────────────────────────────────────────────────────────────────────
# Product & Research one-click deploy — copy to .env and fill in.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# --- Your domain (point its DNS A record at this server) ---
# Primary domain serves GPT Researcher.
DOMAIN=research.example.com
ACME_EMAIL=you@example.com

# ─────────────────────────────────────────────────────────────────────────────
# GPT Researcher (autonomous research agent)
# ─────────────────────────────────────────────────────────────────────────────
# Search provider — the default retriever needs a Tavily API key (tavily.com).
TAVILY_API_KEY=

# LLM: point at any OpenAI-compatible endpoint (self-hosted, Ollama, a gateway…).
# Models use the provider:model format — keep the openai: prefix for any
# OpenAI-compatible server and set LLM_BASE_URL to its /v1 URL.
LLM_BASE_URL=
LLM_API_KEY=
FAST_LLM=openai:gpt-4o-mini
SMART_LLM=openai:gpt-4o
STRATEGIC_LLM=openai:gpt-4o
EMBEDDING=openai:text-embedding-3-small
