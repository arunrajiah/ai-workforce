# ─────────────────────────────────────────────────────────────────────────────
# Customer Support one-click deploy — copy to .env and fill in.
#   cp .env.example .env
# Generate secrets with:  openssl rand -hex 64   (SECRET_KEY_BASE)
#                         openssl rand -hex 24   (passwords)
# ─────────────────────────────────────────────────────────────────────────────

# --- Your domain (point its DNS A record at this server) ---
DOMAIN=support.example.com
ACME_EMAIL=you@example.com

# --- Chatwoot core ---
SECRET_KEY_BASE=replace_with_openssl_rand_hex_64
FRONTEND_URL=https://support.example.com
RAILS_ENV=production
NODE_ENV=production
INSTALLATION_ENV=docker
RAILS_SERVE_STATIC_FILES=true
FORCE_SSL=true
DEFAULT_LOCALE=en
RAILS_MAX_THREADS=5

# --- Database (Postgres/pgvector) ---
POSTGRES_HOST=postgres
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=replace_with_a_strong_password
POSTGRES_DATABASE=chatwoot

# --- Redis ---
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=replace_with_a_strong_password

# --- Storage ---
ACTIVE_STORAGE_SERVICE=local

# --- Email (so Chatwoot can invite agents & send notifications) ---
# Any SMTP provider works (Postmark, SendGrid, Mailgun, your own).
MAILER_SENDER_EMAIL=Support <support@example.com>
SMTP_ADDRESS=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_DOMAIN=example.com

# ─────────────────────────────────────────────────────────────────────────────
# AI Support Agent (the bot that auto-answers tickets from your docs)
# ─────────────────────────────────────────────────────────────────────────────
# Leave LLM_* blank to run the bot in offline demo mode (extractive answers).
# To synthesize answers, point at any OpenAI-compatible endpoint (Ollama, etc.).
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=

# Filled in during GO-LIVE.md Step 6 (after Chatwoot is running):
CHATWOOT_API_TOKEN=
CHATWOOT_ACCOUNT_ID=1
