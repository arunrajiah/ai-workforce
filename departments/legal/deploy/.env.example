# ─────────────────────────────────────────────────────────────────────────────
# Legal & Compliance one-click deploy — copy to .env and fill in.
#   cp .env.example .env
# Generate secrets with:  openssl rand -hex 32   (JWT_SECRET)
# ─────────────────────────────────────────────────────────────────────────────

# --- Your domain (point its DNS A record at this server) ---
# DOMAIN → the private doc-Q&A app (AnythingLLM)
DOMAIN=legal.example.com
ACME_EMAIL=you@example.com

# --- AnythingLLM ---
JWT_SECRET=replace_with_openssl_rand_hex_32

# ─────────────────────────────────────────────────────────────────────────────
# LLM — provider-neutral. For maximum privacy the default is a LOCAL Ollama,
# so confidential documents never leave your network.
# ─────────────────────────────────────────────────────────────────────────────
# Default: local Ollama (run `ollama serve` on the host, `ollama pull llama3.1`).
LLM_PROVIDER=ollama
OLLAMA_BASE_PATH=http://host.docker.internal:11434
OLLAMA_MODEL_PREF=llama3.1
OLLAMA_MODEL_TOKEN_LIMIT=4096

# Alternative: any OpenAI-compatible endpoint. To use it, set:
#   LLM_PROVIDER=generic-openai
# and fill in the three values below (leave Ollama vars as-is or blank).
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=
LLM_MODEL_TOKEN_LIMIT=4096
